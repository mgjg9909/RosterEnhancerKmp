<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme: sfondo scuro per evitare il flash bianco durante le transizioni -->
    <style name="Theme.RosterEnhancer" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">#000000</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:windowSplashScreenBackground">#000000</item>
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
    </style>

    <style name="Theme.RosterEnhancer.Minimal" parent="Theme.RosterEnhancer">
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
    </style>

    <style name="Theme.RosterEnhancer.Curved" parent="Theme.RosterEnhancer">
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
    </style>

    <style name="Theme.RosterEnhancer.Straight" parent="Theme.RosterEnhancer">
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
    </style>

    <style name="Theme.RosterEnhancer.Ascent" parent="Theme.RosterEnhancer">
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
    </style>
</resources>
